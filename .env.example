# Copiar a .env:  cp .env.example .env
# Valores solo para desarrollo local (no usar en producción).

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# InfluxDB 2 (init del contenedor)
INFLUXDB_USER=admin
INFLUXDB_PASS=admin12345
INFLUXDB_ORG=signal-catcher
INFLUXDB_BUCKET=events
INFLUXDB_TOKEN=my-super-secret-influx-token

# MinIO (S3 compatible)
MINIO_USER=minioadmin
MINIO_PASS=minioadmin123
MINIO_BUCKET=raw-events

# Grafana (login en la UI)
GRAFANA_USER=admin
GRAFANA_PASS=admin123
